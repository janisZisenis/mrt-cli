#!/usr/bin/env bash

set -e

rootDir=$1
shift

ALL_FLAG="--all"

help() {
	dir=$(dirname "$0")
	commandName=${dir##*/}

	printf 'Builds a binary for the current platform.\n'
	printf '\n'
	printf '\tmrt run %s\n' "$commandName"
	printf '\n'
	printf "Flags: \n"
	printf -- "-h, --help\tShow this help message\n"
	printf -- '%s\t\tBuild for all supported platforms\n' "$ALL_FLAG"
}

all=false
while [ "$#" -gt 0 ]; do
	case $1 in
	"--help" | "-h")
		help
		exit 0
		;;
	"$ALL_FLAG")
		all=true
		shift
		;;
	*)
		echo "Unknown argument: $1" >&2
		help
		exit 1
		;;
	esac
done

if [[ "$all" == true ]]; then
	(cd "$rootDir" && goreleaser build --snapshot --clean)
else
	(cd "$rootDir" && goreleaser build --snapshot --clean --single-target)
fi
