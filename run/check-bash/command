#!/usr/bin/env bash
set -e

RED="\e[31m"
GREEN="\e[32m"
RESET="\e[0m"

FLAG_FIX="--fix"
FLAG_HELP_SHORT="-h"
FLAG_HELP_LONG="--help"

function display_help() {
	cat <<EOF
Usage: mrt run $(basename "$(dirname "$0")") [OPTIONS]

Check bash scripts for formatting and linting issues. By default, reports issues without modifying files.

Options:
  $FLAG_FIX                      Fix formatting issues. Note: linting issues (shellcheck) cannot be auto-fixed.
  $FLAG_HELP_SHORT|$FLAG_HELP_LONG   Display this help message and exit.
EOF
}

rootDir="$1"
shift

fix=false

while [[ $# -gt 0 ]]; do
	case "$1" in
	"$FLAG_FIX")
		fix=true
		shift
		;;
	"$FLAG_HELP_SHORT" | "$FLAG_HELP_LONG")
		display_help
		exit 0
		;;
	--*)
		echo "Error: Unknown option '$1'."
		echo
		display_help
		exit 1
		;;
	esac
done

readarray -t bash_files < <(mrt --team-dir "$rootDir" run find-bash-files)

exit_code=0

function check_file() {
	local file="$1"
	local file_exit=0

	if shellcheck "$file"; then
		echo -e "${GREEN}✓ $file (lint)${RESET}"
	else
		echo -e "${RED}✗ Linting issues found in $file${RESET}"
		file_exit=1
	fi

	if [[ "$fix" == true ]]; then
		shfmt -w "$file" || file_exit=1
	else
		if shfmt -d "$file"; then
			echo -e "${GREEN}✓ $file (format)${RESET}"
		else
			echo -e "${RED}✗ Formatting issues found in $file${RESET}"
			file_exit=1
		fi
	fi

	return "$file_exit"
}

for file in "${bash_files[@]}"; do
	if [[ -f "$file" && -s "$file" && -r "$file" ]]; then
		check_file "$file" || exit_code=1
	else
		echo -e "${RED}Skipping invalid file: $file${RESET}"
	fi
done

echo -e "All files processed."
exit $exit_code
